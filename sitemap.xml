---
layout: null
permalink: /sitemap.xml
sitemap:
  exclude: 'yes'
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
{% for page in site.pages -%}
  {%- assign include_page = false -%}
  {%- if page.title and page.lang == site.lang -%}
    {%- unless page.sitemap.exclude == "yes" or page.name == "feed.xml" -%}
      {%- assign include_page = true -%}
    {%- endunless -%}
  {%- endif -%}
  {%- if include_page -%}
<url>
  <loc>{{ site.url }}{{ page.url }}</loc>
  {% assign lastmod = site.time -%}
  {%- if page.date -%}{%- assign lastmod = page.date -%}{%- endif -%}
  {%- if page.sitemap.lastmod -%}{%- assign lastmod = page.sitemap.lastmod -%}{%- endif -%}
  <lastmod>{{ lastmod | date: "%Y-%m-%d" }}</lastmod>
  {% if page.layout == "country" -%}
    {%- assign gallery-path = "photos/" | append: page.ref -%}
    {%- for image in site.static_files -%}
      {%- assign is_thumbnail = false -%}
      {%- if image.path contains '-th.' -%}{%- assign is_thumbnail = true -%}{%- endif -%}
      {%- if image.path contains gallery-path and image.extname == ".webp" and is_thumbnail == false -%}
  <image:image><image:loc>{{ site.url }}{{ image.path }}</image:loc></image:image>
  {% endif -%}
    {%- endfor -%}
  {%- endif -%}
  {%- assign alternates = site.pages | where: "ref", page.ref -%}
  {%- for alt in alternates -%}
  <xhtml:link rel="alternate" hreflang="{{ alt.lang }}" href="{{ site.url }}{{ alt.url }}" />
  {% endfor -%}
</url>
  {% endif -%}
{%- endfor -%}
</urlset>
